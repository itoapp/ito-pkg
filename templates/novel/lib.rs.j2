use ito_rs::export_novel_plugin;
use ito_rs::provider::NovelProvider;
use ito_rs::models::{Listing, FilterItem, Page, HomeLayout};
use ito_rs::models::novel::{Novel, Chapter, PageResult};

struct MyNovelPlugin;

impl NovelProvider for MyNovelPlugin {
    fn get_home() -> HomeLayout {
        HomeLayout { components: vec![] }
    }

    fn get_novel_list(listing: Listing, page: i32) -> PageResult {
        PageResult { entries: vec![], has_next_page: false }
    }

    fn get_search_novel_list(query: String, page: i32, filters: Vec<FilterItem>) -> PageResult {
        PageResult { entries: vec![], has_next_page: false }
    }

    fn get_novel_update(novel: Novel, needs_details: bool, needs_chapters: bool) -> Novel {
        novel
    }

    fn get_chapter_content(novel: Novel, chapter: Chapter) -> Vec<Page> {
        vec![]
    }
}

export_novel_plugin!(MyNovelPlugin);
