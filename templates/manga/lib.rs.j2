use ito_rs::export_manga_plugin;
use ito_rs::provider::MangaProvider;
use ito_rs::models::{Listing, FilterItem, Page, HomeLayout};
use ito_rs::models::manga::{Manga, Chapter, PageResult};

struct MyMangaPlugin;

impl MangaProvider for MyMangaPlugin {
    fn get_home() -> HomeLayout {
        HomeLayout { components: vec![] }
    }

    fn get_manga_list(listing: Listing, page: i32) -> PageResult {
        PageResult { entries: vec![], has_next_page: false }
    }

    fn get_search_manga_list(query: String, page: i32, filters: Vec<FilterItem>) -> PageResult {
        PageResult { entries: vec![], has_next_page: false }
    }

    fn get_manga_update(manga: Manga, needs_details: bool, needs_chapters: bool) -> Manga {
        manga
    }

    fn get_page_list(manga: Manga, chapter: Chapter) -> Vec<Page> {
        vec![]
    }
}

export_manga_plugin!(MyMangaPlugin);
